{
  "name": "oxsteed-v2-server",
  "version": "2.0.0",
  "description": "OxSteed v2 API server",
  "main": "index.js",
  "scripts": {
    "start": "node migrate.js && node index.js",
    "migrate": "node migrate.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "./__tests__/setup.js"
    ],
    "testTimeout": 15000
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1021.0",
    "@aws-sdk/s3-request-presigner": "3.1021.0",
    "@otplib/v12-adapter": "^13.4.0",
    "bcrypt": "6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "expo-server-sdk": "^3.7.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.1.0",
    "file-type": "^16.5.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "2.1.1",
    "node-cron": "^3.0.3",
    "otplib": "^13.4.0",
    "pg": "^8.11.0",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.7.0",
    "stripe": "^14.0.0",
    "twilio": "^4.19.0",
    "web-push": "^3.6.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
