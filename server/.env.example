# ===========================================
# OxSteed v2 — Server Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ---- Core ----
PORT=5000
NODE_ENV=development
DATABASE_URL=postgres://user:password@localhost:5432/oxsteed
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ---- JWT / Auth ----
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# ---- AWS S3 (file uploads) ----
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=oxsteed-media

# ---- Twilio (SMS / OTP) ----
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+13305550100

# ---- Email (Resend) ----
RESEND_API_KEY=your_resend_key

# ---- Push Notifications (VAPID) ----
VAPID_PUBLIC_KEY=generated_once
VAPID_PRIVATE_KEY=generated_once_store_in_secrets

# ---- Google Maps / Geo ----
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ---- Redis (optional, distributed rate limiting) ----
REDIS_URL=redis://localhost:6379

# ==============================
# Phase 6 Additions
# ==============================

# ---- Analytics ----
ANALYTICS_ENABLED=true

# ---- Referral System ----
REFERRAL_REWARD_TYPE=freemonth_tier2

# ---- Due Diligence Export (Phase 7) ----
DD_EXPORT_BUCKET=oxsteed-dd-exports

# ---- Didit (Identity Verification) ----
DIDIT_API_KEY=your_didit_api_key
DIDIT_WORKFLOW_ID=3d74f89a-8a9a-4a0a-a401-1501baaf2b7d
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret
